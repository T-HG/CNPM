PORT=5055
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
DATABASE_FILE=backend/database/pharmacy.sqlite

# ─── SMTP — gửi mật khẩu mới khi quên mật khẩu ─────────────────────────────
# Sao chép file này thành `.env` ở thư mục gốc project và điền giá trị thật.
#
# Gmail (khuyến nghị dev):
#   1) Bật xác minh 2 bước: https://myaccount.google.com/security
#   2) Tạo "Mật khẩu ứng dụng": https://myaccount.google.com/apppasswords
#   3) Dùng mật khẩu 16 ký tự (không phải mật khẩu đăng nhập Gmail) cho SMTP_PASS
#
# Microsoft / Outlook cá nhân:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# Cổng 465 (SSL): đặt SMTP_SECURE=true và SMTP_PORT=465
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Tùy chọn — để trống thì dùng cùng email SMTP_USER
SMTP_FROM=

# Gỡ lỗi kết nối SMTP (log chi tiết trong console API)
# SMTP_DEBUG=true

# Khi đã cấu hình SMTP đủ 5 biến trên, email thật sẽ được gửi.
# Độ dài mật khẩu mới khi quên mật khẩu (6–32, mặc định 6)
# FORGOT_PASSWORD_LENGTH=6

# Dev: nếu CHƯA điền SMTP, mặc định vẫn đổi mật khẩu và in ra console API.
# Tắt hành vi in console: FORGOT_PASSWORD_DEV_LOG=false
# FORGOT_PASSWORD_DEV_LOG=false

# Frontend (tùy chọn — dev mặc định /api qua proxy Vite → PORT)
# VITE_API_URL=http://localhost:5055/api
